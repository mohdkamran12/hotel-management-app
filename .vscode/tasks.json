{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build hotel_app",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-Wall",
        "-Wextra",
        "-pedantic",
        "${workspaceFolder}/main.cpp",
        "-o",
        "${workspaceFolder}/hotel_app.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
